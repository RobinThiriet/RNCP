POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=change-me-now

WEBAPP_CONTEXT=ROOT
PROXY_ALLOWED_IPS_REGEX=172\\.30\\.0\\.10

SAML_ENABLED=true
SAML_IDP_METADATA_URL=
SAML_ENTITY_ID=https://guacamole.example.com/
SAML_CALLBACK_URL=https://guacamole.example.com/
SAML_GROUP_ATTRIBUTE=groups
SAML_STRICT=true
SAML_COMPRESS_REQUEST=true
SAML_COMPRESS_RESPONSE=true
SAML_DEBUG=false

POSTGRESQL_AUTO_CREATE_ACCOUNTS=true
POSTGRESQL_TRACK_EXTERNAL_CONNECTION_HISTORY=true

EXTENSION_PRIORITY=saml, postgresql
RECORDING_ENABLED=true
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
